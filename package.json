{
	"name": "sirrobbit",
	"version": "1.0.8",
	"private": true,
	"engines": {
		"node": ">=20.0.0"
	},
	"type": "module",
	"main": "dist/main.js",
	"scripts": {
		"dev": "node --loader ts-node/esm/transpile-only src/main.ts",
		"prod": "node dist/main.js",
		"prod-local": "npm run build && npm run prod",
		"build": "tsc --project tsconfig.json && npm run copy-assets",
		"copy-assets": "copyfiles -u 1 \"src/{public,data}/**/*\" dist",
		"prettier": "npx prettier . --write \"**/*.ts\""
	},
	"dependencies": {
		"@discordx/importer": "^1.3.3",
		"@types/node": "^20.19.9",
		"copyfiles": "^2.4.1",
		"cron": "^3.5.0",
		"discord.js": "^14.21.0",
		"discordx": "^11.12.5",
		"dotenv": "^16.6.1",
		"embed-table": "^4.2.3",
		"got": "^14.4.7",
		"i18next": "^23.16.8",
		"jimp": "^0.22.12",
		"jsdom": "^24.1.3",
		"json-2-csv": "^5.5.9",
		"node-cron": "^3.0.3",
		"pino": "^9.7.0",
		"pino-pretty": "^11.3.0",
		"rainbowvis.js": "^1.1.1",
		"reflect-metadata": "^0.2.2",
		"superagent": "^9.0.2",
		"tesseract.js": "^5.1.1"
	},
	"devDependencies": {
		"@types/got": "^9.6.12",
		"@types/jsdom": "^21.1.7",
		"@types/superagent": "^8.1.9",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"better-npm-audit": "3.7.3",
		"cross-env": "^7.0.3",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.2",
		"eslint-plugin-prettier": "^5.5.3",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"nodemon": "^3.1.10",
		"npm-check-updates": "16.14.20",
		"prettier": "^3.6.2",
		"ts-node": "^10.9.2",
		"typescript": "^5.8.3"
	}
}